@*
    Login View - This is the login page users see when they are not authenticated
    Comments in Razor views use this at symbol asterisk syntax
*@

@{
    // Set the page title that appears in the browser tab
    ViewData["Title"] = "Login";
    // Set layout to null so the login page has its own clean design
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Weather App</title>
    <style>
        /* Reset default browser styles */
        * { margin: 0; padding: 0; box-sizing: border-box; }

        /* Full page background with gradient */
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Login card container */
        .login-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        /* App title at top of login card */
        h2 {
            color: white;
            text-align: center;
            margin-bottom: 8px;
            font-size: 28px;
        }

        /* Subtitle under the title */
        .subtitle {
            color: rgba(255,255,255,0.6);
            text-align: center;
            margin-bottom: 30px;
            font-size: 14px;
        }

        /* Input field styling */
        input {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 16px;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px;
            background: rgba(255,255,255,0.1);
            color: white;
            font-size: 15px;
            outline: none;
        }

        /* Placeholder text color */
        input::placeholder { color: rgba(255,255,255,0.5); }

        /* Input focus effect */
        input:focus { border-color: rgba(255,255,255,0.5); }

        /* Login button styling */
        button {
            width: 100%;
            padding: 12px;
            background: #e94560;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 8px;
        }

        /* Button hover effect */
        button:hover { background: #c73652; }

        /* Error message styling */
        .error {
            color: #ff6b6b;
            text-align: center;
            margin-bottom: 16px;
            font-size: 14px;
        }

        /* Link to register page */
        .register-link {
            text-align: center;
            margin-top: 20px;
            color: rgba(255,255,255,0.6);
            font-size: 14px;
        }

        /* Register link styling */
        .register-link a { color: #e94560; text-decoration: none; }
    </style>
</head>
<body>
    <div class="login-container">
        <h2>🌤 Weather App</h2>
        <p class="subtitle">Sign in to view your dashboard</p>

        @* Show error message if login failed *@
        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        @* Login form - posts to AccountController Login action *@
        <form method="post" action="/Account/Login">
            @* Anti-forgery token for security - prevents cross site request forgery attacks *@
            @Html.AntiForgeryToken()

            <input type="text" name="username" placeholder="Username" required />
            <input type="password" name="password" placeholder="Password" required />
            <button type="submit">Sign In</button>
        </form>

        <div class="register-link">
            Don't have an account? <a href="/Account/Register">Register here</a>
        </div>
    </div>
</body>
</html>